<Window x:Class="ModernClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Опросник СМК" Height="750" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="20,10">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#BDBDBD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2196F3" Padding="25,20">
            <StackPanel>
                <TextBlock Text="📋 Опросник СМК" FontSize="28" FontWeight="Bold" 
                          Foreground="White"/>
                <TextBlock Text="Оценка качества образовательных услуг" 
                          FontSize="14" Foreground="#E3F2FD" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Основное содержимое -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled" Padding="20">
            <StackPanel>
                <!-- Карточка параметров -->
                <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Факультет:" 
                                   VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cmbFaculty" 
                                  Style="{StaticResource ModernComboBox}" Width="200"
                                  HorizontalAlignment="Left" SelectedIndex="0">
                            <ComboBoxItem Content="Информационных технологий" Tag="0"/>
                            <ComboBoxItem Content="Экономический" Tag="1"/>
                            <ComboBoxItem Content="Юридический" Tag="2"/>
                            <ComboBoxItem Content="Инженерный" Tag="3"/>
                            <ComboBoxItem Content="Медицинский" Tag="4"/>
                        </ComboBox>

                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Форма обучения:" 
                                   VerticalAlignment="Center" FontWeight="SemiBold" FontSize="14"/>
                        <ComboBox Grid.Row="0" Grid.Column="3" x:Name="cmbEduForm" 
                                  Style="{StaticResource ModernComboBox}" Width="150"
                                  HorizontalAlignment="Left" SelectedIndex="0">
                            <ComboBoxItem Content="Очная" Tag="1"/>
                            <ComboBoxItem Content="Заочная" Tag="0"/>
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- Карточка вопросов -->
                <Border Background="White" CornerRadius="10" Padding="20" Margin="0,0,0,20"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Вопросы анкеты" FontSize="18" FontWeight="Bold" 
                                   Margin="0,0,0,15" Foreground="#1976D2"/>

                        <ItemsControl x:Name="questionsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" 
                                            Padding="0,10" Margin="0,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="220"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding Text}" 
                                                       VerticalAlignment="Center" FontSize="14"
                                                       TextWrapping="Wrap" Margin="0,5,15,5"/>

                                            <ComboBox Grid.Column="1" x:Name="cmbAnswer" 
                                                      Style="{StaticResource ModernComboBox}"
                                                      Width="200" HorizontalAlignment="Left"
                                                      SelectedIndex="0">
                                                <ComboBoxItem Content="Удовлетворён" Tag="0"/>
                                                <ComboBoxItem Content="Скорее удовлетворён" Tag="1"/>
                                                <ComboBoxItem Content="Скорее не удовлетворён" Tag="2"/>
                                                <ComboBoxItem Content="Не удовлетворён" Tag="3"/>
                                            </ComboBox>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Кнопка отправки -->
                <Button x:Name="btnSend" Content="ОТПРАВИТЬ ОТВЕТЫ" 
                        Style="{StaticResource ModernButton}" Margin="0,10,0,10"
                        Click="btnSend_Click"/>

                <!-- Кнопка администратора -->
                <Button x:Name="btnAdmin" Content="👨‍💼 АДМИНИСТРИРОВАНИЕ" 
                        Style="{StaticResource ModernButton}" 
                        Background="#9C27B0" Margin="0,10,0,20"
                        Click="btnAdmin_Click"/>

                <!-- Результат -->
                <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,20"
                        BorderBrush="#E0E0E0" BorderThickness="1">
                    <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="tbResult" TextWrapping="Wrap" 
                                   FontFamily="Consolas" FontSize="12"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Нижний колонтитул -->
        <Border Grid.Row="2" Background="#F5F5F5" Padding="10" BorderBrush="#E0E0E0" 
                BorderThickness="0,1,0,0">
            <TextBlock Text="© 2024 Система опросов СМК" FontSize="11" 
                       Foreground="#757575" HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>