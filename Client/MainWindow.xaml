<Window x:Class="Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TCP Клиент (опросник СМК)" Height="700" Width="720"
        WindowStartupLocation="CenterScreen">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="10">
        <StackPanel>
            <!-- Параметры: факультет и форма обучения -->
            <GroupBox Header="Параметры" Margin="0,0,0,15" Padding="5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="ID факультета (0-127):" VerticalAlignment="Center" Margin="5"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtFacultyId" Width="120" Text="0" Margin="5" HorizontalAlignment="Left"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Форма обучения:" VerticalAlignment="Center" Margin="5"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cbEducationForm" Width="150" Margin="5" HorizontalAlignment="Left" SelectedIndex="0">
                        <ComboBoxItem Content="Очная" Tag="0"/>
                        <ComboBoxItem Content="Заочная" Tag="1"/>
                    </ComboBox>
                </Grid>
            </GroupBox>

            <!-- 16 вопросов в две колонки -->
            <GroupBox Header="Ответы на вопросы (введите число от 0 до 3)" Padding="5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Левая колонка: вопросы 1-8 -->
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Вопрос 1:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="txtAnswer1" Text="0"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Вопрос 2:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="txtAnswer2" Text="0"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Вопрос 3:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="txtAnswer3" Text="0"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Вопрос 4:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="txtAnswer4" Text="0"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Вопрос 5:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="txtAnswer5" Text="0"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Вопрос 6:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="txtAnswer6" Text="0"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Вопрос 7:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="txtAnswer7" Text="0"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Вопрос 8:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="txtAnswer8" Text="0"/>
                        </Grid>
                    </StackPanel>

                    <!-- Правая колонка: вопросы 9-16 -->
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Вопрос 9:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="txtAnswer9" Text="0"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Вопрос 10:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="txtAnswer10" Text="0"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Вопрос 11:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="txtAnswer11" Text="0"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Вопрос 12:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="txtAnswer12" Text="0"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Вопрос 13:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="txtAnswer13" Text="0"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Вопрос 14:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="txtAnswer14" Text="0"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Вопрос 15:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="txtAnswer15" Text="0"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Вопрос 16:" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="txtAnswer16" Text="0"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <Button x:Name="btnSend" Content="Отправить ответы" Click="btnSend_Click" Margin="0,15" Height="35" FontSize="14"/>

            <!-- Блок с результатом отправки и отладочной информацией -->
            <Border BorderBrush="Gray" BorderThickness="1" Padding="8" Margin="0,5">
                <TextBlock x:Name="tbResult" TextWrapping="Wrap" Text="Готов к отправке"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>