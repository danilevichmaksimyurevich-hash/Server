<Window x:Class="ModernClient.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель администратора" Height="800" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="15,8">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1976D2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#F44336"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D32F2F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WarningButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#FF9800"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F57C00"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#BDBDBD"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#9C27B0" Padding="25,20">
            <StackPanel>
                <TextBlock Text="👨‍💼 Панель администратора" FontSize="28" FontWeight="Bold" 
                          Foreground="White"/>
                <TextBlock Text="Управление опросами и просмотр статистики" 
                          FontSize="14" Foreground="#E1BEE7" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Табы -->
        <TabControl Grid.Row="1" Margin="20" Background="White" BorderThickness="0">
            <!-- Вкладка статистики -->
            <TabItem Header="📊 Статистика опросов" FontSize="14" FontWeight="SemiBold">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Кнопки управления -->
                    <Border Grid.Row="0" Background="#F5F5F5" CornerRadius="8" Padding="15" 
                            Margin="0,0,0,15">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnLoadStats" Content="📈 Загрузить статистику" 
                                    Style="{StaticResource ModernButton}" Width="200"
                                    Click="btnLoadStats_Click" Margin="0,0,10,0"/>

                            <Button x:Name="btnLoadAllStats" Content="🌍 Статистика по всем" 
                                    Style="{StaticResource ModernButton}" Width="200"
                                    Click="btnLoadAllStats_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Фильтры -->
                    <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" 
                            Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="10">
                                <TextBlock Text="Факультет:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <ComboBox x:Name="cmbStatsFaculty" Style="{StaticResource ModernComboBox}" 
                                          Width="220" SelectedIndex="0">
                                    <ComboBoxItem Content="Все факультеты" Tag="31"/>
                                    <ComboBoxItem Content="Информационных технологий" Tag="0"/>
                                    <ComboBoxItem Content="Экономический" Tag="1"/>
                                    <ComboBoxItem Content="Юридический" Tag="2"/>
                                    <ComboBoxItem Content="Инженерный" Tag="3"/>
                                    <ComboBoxItem Content="Медицинский" Tag="4"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10">
                                <TextBlock Text="Форма обучения:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <ComboBox x:Name="cmbStatsForm" Style="{StaticResource ModernComboBox}" 
                                          Width="150" SelectedIndex="0">
                                    <ComboBoxItem Content="Все формы" Tag="0"/>
                                    <ComboBoxItem Content="Очная" Tag="1"/>
                                    <ComboBoxItem Content="Заочная" Tag="0"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="10">
                                <Button x:Name="btnResetStats" Content="🗑️ Сбросить статистику" 
                                        Style="{StaticResource DangerButton}" Width="200"
                                        Click="btnResetStats_Click" Margin="0,25,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Результаты статистики -->
                    <Border Grid.Row="2" Background="#F5F5F5" CornerRadius="8" Padding="10" 
                            Margin="0,0,0,10">
                        <TextBlock x:Name="tbStatsInfo" Text="Нажмите 'Загрузить статистику' для просмотра данных"
                                   FontSize="12" Foreground="#757575"/>
                    </Border>

                    <!-- Таблица статистики -->
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" 
                                  HorizontalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="statsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="8" Padding="15" 
                                            Margin="0,0,0,10" BorderBrush="#E0E0E0" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Text="{Binding QuestionText}" 
                                                       FontWeight="Bold" FontSize="14" 
                                                       Margin="0,0,0,15" Foreground="#1976D2"/>

                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Удовлетворён -->
                                                <Border Grid.Column="0" Background="#4CAF50" CornerRadius="6" 
                                                        Padding="10" Margin="5">
                                                    <StackPanel>
                                                        <TextBlock Text="✅ Удовлетворён" Foreground="White" 
                                                                   TextAlignment="Center" FontSize="12"/>
                                                        <TextBlock Text="{Binding Satisfied}" Foreground="White" 
                                                                   FontSize="24" FontWeight="Bold" 
                                                                   TextAlignment="Center" Margin="0,5,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Скорее удовлетворён -->
                                                <Border Grid.Column="1" Background="#8BC34A" CornerRadius="6" 
                                                        Padding="10" Margin="5">
                                                    <StackPanel>
                                                        <TextBlock Text="👍 Скорее удовлетворён" Foreground="White" 
                                                                   TextAlignment="Center" FontSize="12"/>
                                                        <TextBlock Text="{Binding MostlySatisfied}" Foreground="White" 
                                                                   FontSize="24" FontWeight="Bold" 
                                                                   TextAlignment="Center" Margin="0,5,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Скорее не удовлетворён -->
                                                <Border Grid.Column="2" Background="#FF9800" CornerRadius="6" 
                                                        Padding="10" Margin="5">
                                                    <StackPanel>
                                                        <TextBlock Text="🤔 Скорее не удовлетворён" Foreground="White" 
                                                                   TextAlignment="Center" FontSize="12"/>
                                                        <TextBlock Text="{Binding MostlyUnsatisfied}" Foreground="White" 
                                                                   FontSize="24" FontWeight="Bold" 
                                                                   TextAlignment="Center" Margin="0,5,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Не удовлетворён -->
                                                <Border Grid.Column="3" Background="#F44336" CornerRadius="6" 
                                                        Padding="10" Margin="5">
                                                    <StackPanel>
                                                        <TextBlock Text="❌ Не удовлетворён" Foreground="White" 
                                                                   TextAlignment="Center" FontSize="12"/>
                                                        <TextBlock Text="{Binding Unsatisfied}" Foreground="White" 
                                                                   FontSize="24" FontWeight="Bold" 
                                                                   TextAlignment="Center" Margin="0,5,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- Вкладка управления -->
            <TabItem Header="⚙️ Управление сервером" FontSize="14" FontWeight="SemiBold">
                <Grid Margin="10">
                    <Border Background="White" CornerRadius="10" Padding="25" 
                            BorderBrush="#E0E0E0" BorderThickness="1"
                            VerticalAlignment="Top" Height="300">
                        <StackPanel>
                            <TextBlock Text="Управление состоянием сервера" FontSize="18" 
                                       FontWeight="Bold" Margin="0,0,0,20" Foreground="#1976D2"/>

                            <Button x:Name="btnTogglePause" Content="⏸️ Приостановить приём опросов" 
                                    Style="{StaticResource WarningButton}" Width="300"
                                    Click="btnTogglePause_Click" Margin="0,10"/>

                            <Border Background="#F5F5F5" CornerRadius="8" Padding="15" Margin="0,30,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="Статус сервера:" FontSize="14" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="tbServerStatus" Text="Активен" 
                                               FontSize="14" FontWeight="Bold" Foreground="#4CAF50"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>